{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreBinaries": ["trunk"],
  "workspaces": {
    ".": {
      "entry": ["stylelint.config.mjs"],
      "project": ["**/*.{js,cjs,mjs,ts,cts,mts}", "!packages/**", "!.trunk/**", "!node_modules/**"]
    },
    "packages/*": {
      "project": ["src/**/*.ts"]
    }
  }
}
